{
  "schemaVersion": 1,
  "description": "BIP-173 Bech32 Specification Test Vectors",
  "testCases": [
    {
      "bipSection": "BIP-173 - Minimal example (empty data)",
      "hrp": "a",
      "payloadHex": "",
      "expectedEncoded": "a12uel5l",
      "decodedHrp": "a",
      "decodedPayloadHex": "",
      "roundtripValid": true
    },
    {
      "bipSection": "BIP-173 - Long HRP (83 characters, empty data)",
      "hrp": "an83characterlonghumanreadablepartthatcontainsthenumber1andtheexcludedcharactersbio",
      "payloadHex": "",
      "expectedEncoded": "an83characterlonghumanreadablepartthatcontainsthenumber1andtheexcludedcharactersbio1tt5tgs",
      "decodedHrp": "an83characterlonghumanreadablepartthatcontainsthenumber1andtheexcludedcharactersbio",
      "decodedPayloadHex": "",
      "roundtripValid": true
    },
    {
      "bipSection": "BIP-173 - HRP with payload",
      "hrp": "abcdef",
      "payloadHex": "751ef1",
      "expectedEncoded": "abcdef1w500z79ug4j",
      "decodedHrp": "abcdef",
      "decodedPayloadHex": "751ef1",
      "roundtripValid": true
    },
    {
      "bipSection": "BIP-173 - All valid characters test",
      "hrp": "split",
      "payloadHex": "c5f38b",
      "expectedEncoded": "split1checkfp633e",
      "decodedHrp": "split",
      "decodedPayloadHex": "c5f38b",
      "roundtripValid": true
    }
  ],
  "polymadTests": [
    {
      "description": "Valid checksum produces polymod == 1",
      "input": "a12uel5l",
      "expectedPolymadResult": 1
    }
  ],
  "bitConversionTests": [
    {
      "description": "8-bit to 5-bit conversion roundtrip",
      "eightBitHex": "751ef1",
      "description8to5": [
        22,
        17,
        29,
        17
      ]
    }
  ],
  "caseSensitivityTests": [
    {
      "description": "BIP-173 allows all lowercase",
      "input": "a12uel5l",
      "shouldDecode": true
    },
    {
      "description": "BIP-173 allows all uppercase",
      "input": "A12UEL5L",
      "shouldDecode": true
    },
    {
      "description": "BIP-173 rejects mixed case",
      "input": "a12Uel5L",
      "shouldDecode": false
    }
  ]
}